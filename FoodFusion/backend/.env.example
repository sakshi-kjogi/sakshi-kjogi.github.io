# Supabase project URL (from Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Direct PostgreSQL connection (Settings → Database → Connection string → URI, port 5432)
# Append ?sslmode=require for Supabase
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres?sslmode=require

# Long random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# development | production  (sets Secure flag on cookies in production)
ENVIRONMENT=development

# JSON array of allowed CORS origins
CORS_ORIGINS=["http://localhost:5173"]
